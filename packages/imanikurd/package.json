{
  "name": "imanikurd",
  "version": "1.1.0",
  "description": "Complete Islamic toolkit for Kurdish community — full Quran (6236 ayahs), 13 Kurdish Tafsirs, Qibla, prayer times, dhikr, hadith, and more",
  "keywords": [
    "islam",
    "quran",
    "kurdish",
    "kurdistan",
    "qibla",
    "prayer-times",
    "dhikr",
    "azkar",
    "tafsir",
    "hadith",
    "imanikurd"
  ],
  "author": "Abdulla090",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdulla090/imanikurd.git",
    "directory": "packages/imanikurd"
  },
  "homepage": "https://github.com/Abdulla090/imanikurd#readme",
  "bugs": {
    "url": "https://github.com/Abdulla090/imanikurd/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "extract-data": "node scripts/extract-data.cjs",
    "prepublishOnly": "npm run extract-data && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "imanikurd-hadith": "^1.1.0",
    "imanikurd-prayer": "^1.1.0",
    "imanikurd-quran": "^1.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^1.6.0"
  }
}
