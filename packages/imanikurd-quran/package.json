{
  "name": "imanikurd-quran",
  "version": "1.0.0",
  "description": "Quran database, 13 Kurdish Tafsirs, and audio recitations logic for the Kurdish community",
  "keywords": [
    "islam",
    "quran",
    "kurdish",
    "tafsir",
    "kurdistan"
  ],
  "author": "Abdulla090",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdulla090/imanikurd.git",
    "directory": "packages/imanikurd-quran"
  },
  "homepage": "https://github.com/Abdulla090/imanikurd#readme",
  "bugs": {
    "url": "https://github.com/Abdulla090/imanikurd/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
